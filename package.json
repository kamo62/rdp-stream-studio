{
  "name": "rdp-stream-studio",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter @rdp-stream-studio/web dev",
    "dev:server": "bun --filter @rdp-stream-studio/server dev",
    "dev:web": "bun --filter @rdp-stream-studio/web dev",
    "build": "bun --filter '*' build",
    "test": "bun test",
    "typecheck": "tsc -b",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bun": "^1.3.5",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  },
  "dependencies": {
    "zod": "^4.1.13"
  }
}
